# Neon DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/YOUR_DB_NAME"

# NextAuth.js
AUTH_SECRET=""
AUTH_URL="https://localhost:3000"

# Email whitelist for registration (comma-separated)
# Use @domain.com for domain wildcards, or exact emails
# Leave empty to block all registrations
ALLOWED_EMAILS="@dev.local"

# S3 Bucket
S3_REGION="us-west-2"
S3_BUCKET="YOUR_S3_BUCKET_NAME"
S3_ACCESS_KEY_ID="S3_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="S3_SECRET_KEY"